generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId                            String                        @id @default(cuid())
  username                          String                        @unique
  email                             String                        @unique
  password                          String
  salt                              String
  role                              Roles
  createdAt                         DateTime                      @default(now())
  updatedAt                         DateTime                      @updatedAt
  isDisabled                        Boolean                       @default(false)
  mustChangePassword                Boolean                       @default(false)
  passwordChangedAt                 DateTime?
  employee                          Employee?
  // Users who supervise employees
  supervisedEmployees               Employee[]                    @relation("EmployeeSupervisorUser")
  draftedViolations                 EmployeeViolation[]           @relation("EmployeeViolationDraftedBy")
  reviewedViolations                EmployeeViolation[]           @relation("EmployeeViolationReviewedBy")
  createdViolationResets            EmployeeViolationReset[]      @relation("EmployeeViolationResetCreatedBy")
  createdViolationAutoResetPolicies ViolationAutoResetPolicy[]    @relation("ViolationAutoResetPolicyCreatedBy")
  createdPayrolls                   Payroll[]                     @relation("PayrollCreatedBy")
  managerReviewedPayrolls           Payroll[]                     @relation("PayrollManagerReviewedBy")
  gmReviewedPayrolls                Payroll[]                     @relation("PayrollGmReviewedBy")
  releasedPayrolls                  Payroll[]                     @relation("PayrollReleasedBy")
  createdPayrollEmployees           PayrollEmployee[]             @relation("PayrollEmployeeCreatedBy")
  updatedPayrollEmployees           PayrollEmployee[]             @relation("PayrollEmployeeUpdatedBy")
  createdPayrollEarnings            PayrollEarning[]              @relation("PayrollEarningCreatedBy")
  createdPayrollDeductions          PayrollDeduction[]            @relation("PayrollDeductionCreatedBy")
  createdPositionRateHistories      PositionRateHistory[]         @relation("PositionRateHistoryCreatedBy")
  createdEmployeePositionHistories  EmployeePositionHistory[]     @relation("EmployeePositionHistoryCreatedBy")
  createdDeductionTypes             DeductionType[]               @relation("DeductionTypeCreatedBy")
  updatedDeductionTypes             DeductionType[]               @relation("DeductionTypeUpdatedBy")
  assignedEmployeeDeductions        EmployeeDeductionAssignment[] @relation("EmployeeDeductionAssignmentAssignedBy")
  updatedEmployeeDeductions         EmployeeDeductionAssignment[] @relation("EmployeeDeductionAssignmentUpdatedBy")
  reviewedEmployeeDeductions        EmployeeDeductionAssignment[] @relation("EmployeeDeductionAssignmentReviewedBy")
  recordedEmployeeDeductionPayments EmployeeDeductionPayment[]    @relation("EmployeeDeductionPaymentCreatedBy")
  reviewedCashAdvanceRequests       CashAdvanceRequest[]          @relation("CashAdvanceRequestReviewedBy")
  reviewedLeaveRequests             LeaveRequest[]                @relation("LeaveRequestReviewedBy")
  reviewedDayOffRequests            DayOffRequest[]               @relation("DayOffRequestReviewedBy")
  reviewedScheduleChangeRequests    ScheduleChangeRequest[]       @relation("ScheduleChangeRequestReviewedBy")
  reviewedScheduleSwapRequests      ScheduleSwapRequest[]         @relation("ScheduleSwapRequestReviewedBy")
  updatedAttendanceSecuritySettings AttendanceSecuritySetting[]   @relation("AttendanceSecuritySettingUpdatedBy")
  enrolledEmployeeFaces             EmployeeFaceEnrollment[]      @relation("EmployeeFaceEnrollmentEnrolledBy")
  revokedEmployeeFaces              EmployeeFaceEnrollment[]      @relation("EmployeeFaceEnrollmentRevokedBy")
  createdNotifications              Notification[]               @relation("NotificationActor")
  userNotifications                 UserNotification[]

  @@index([createdAt])
  @@index([role, username])
  @@index([isDisabled, username])
  @@index([mustChangePassword, username])
  @@index([passwordChangedAt])
}

model Notification {
  id            String               @id @default(cuid())
  eventType     NotificationEventType
  module        NotificationModule
  title         String
  message       String
  severity      NotificationSeverity @default(INFO)
  actorUserId   String?
  entityType    String?
  entityId      String?
  linkHref      String
  metadata      Json?
  emailEligible Boolean              @default(false)
  createdAt     DateTime             @default(now())
  actor         User?                @relation("NotificationActor", fields: [actorUserId], references: [userId], onDelete: SetNull)
  recipients    UserNotification[]

  @@index([module, createdAt])
  @@index([eventType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
}

model UserNotification {
  id             String                  @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  archivedAt     DateTime?
  emailedAt      DateTime?
  emailStatus    NotificationEmailStatus @default(PENDING)
  emailError     String?
  createdAt      DateTime                @default(now())
  notification   Notification            @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User                    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt, archivedAt, createdAt])
  @@index([notificationId, createdAt])
  @@index([emailStatus, emailedAt])
}

model Employee {
  employeeId                   String                    @id @default(cuid())
  employeeCode                 String                    @unique
  firstName                    String
  lastName                     String
  middleName                   String?
  suffix                       SUFFIX?
  sex                          GENDER
  civilStatus                  CIVIL_STATUS
  nationality                  String?
  birthdate                    DateTime
  address                      String?
  city                         String?
  state                        String?
  postalCode                   String?
  country                      String?
  img                          String?
  startDate                    DateTime
  isEnded                      Boolean?                  @default(false)
  endDate                      DateTime?
  employmentStatus             EMPLOYMENT_STATUS
  currentStatus                CURRENT_STATUS
  email                        String?
  phone                        String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  emergencyContactEmail        String?
  description                  String?
  isArchived                   Boolean                   @default(false)
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  userId                       String?                   @unique
  user                         User?                     @relation(fields: [userId], references: [userId])
  departmentId                 String?
  positionId                   String?
  supervisorUserId             String?
  department                   Department?               @relation(fields: [departmentId], references: [departmentId])
  position                     Position?                 @relation(fields: [positionId], references: [positionId])
  supervisorUser               User?                     @relation("EmployeeSupervisorUser", fields: [supervisorUserId], references: [userId])
  governmentId                 GovernmentId?             @relation("EmployeeGovernmentId")
  positionHistory              EmployeePositionHistory[]

  // Scheduling links
  weeklySchedules              WeeklySchedule[]
  shiftOverrides               EmployeeShiftOverride[]
  attendances                  Attendance[]
  punches                      Punch[]
  attendanceContextLogs        AttendanceContextLog[]
  faceEnrollments              EmployeeFaceEnrollment[]
  faceVerificationAttempts     FaceVerificationAttempt[]
  employeeViolations           EmployeeViolation[]
  violationResets              EmployeeViolationReset[]
  violationAutoResetPolicies   ViolationAutoResetPolicy[]
  payrollEmployees             PayrollEmployee[]
  deductionAssignments         EmployeeDeductionAssignment[]
  cashAdvanceRequests          CashAdvanceRequest[]
  leaveRequests                LeaveRequest[]
  leaveCreditLedgerEntries     EmployeeLeaveCreditLedger[]
  dayOffRequests               DayOffRequest[]
  scheduleChangeRequests       ScheduleChangeRequest[]
  scheduleSwapRequestsMade     ScheduleSwapRequest[]         @relation("ScheduleSwapRequestRequester")
  scheduleSwapRequestsReceived ScheduleSwapRequest[]         @relation("ScheduleSwapRequestCoworker")

  @@index([isArchived, employeeCode])
  @@index([departmentId])
  @@index([positionId])
}

// ======== ORG STRUCTURE ========= //

/// Department catalog (simple name/description, soft active flag).
model Department {
  departmentId    String                    @id @default(cuid())
  name            String                    @unique
  description     String?
  isActive        Boolean                   @default(true)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  positions       Position[]
  employees       Employee[]
  positionHistory EmployeePositionHistory[]

  @@index([isActive, name])
}

/// Positions (job titles) linked to a department.
model Position {
  positionId   String   @id @default(cuid())
  name         String
  description  String?
  dailyRate    Decimal? @db.Decimal(10, 2)
  hourlyRate   Decimal? @db.Decimal(10, 2)
  monthlyRate  Decimal? @db.Decimal(12, 2)
  currencyCode String   @default("PHP")
  isActive     Boolean  @default(true)
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department      Department                @relation(fields: [departmentId], references: [departmentId])
  employees       Employee[]
  positionHistory EmployeePositionHistory[]
  rateHistory     PositionRateHistory[]

  @@unique([name, departmentId])
  @@index([isActive, departmentId, name])
}

// ======== EMPLOYEE CONTRIBUTION ========= //
model GovernmentId {
  governmentId                   String   @id @default(cuid())
  sssNumber                      String?
  isSssIncludedInPayroll         Boolean  @default(true)
  philHealthNumber               String?
  isPhilHealthIncludedInPayroll  Boolean  @default(true)
  tinNumber                      String?
  isWithholdingIncludedInPayroll Boolean  @default(true)
  pagIbigNumber                  String?
  isPagIbigIncludedInPayroll     Boolean  @default(true)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  employeeId                     String   @unique
  employee                       Employee @relation("EmployeeGovernmentId", fields: [employeeId], references: [employeeId])
}

model ContributionBracket {
  id                  String                        @id @default(cuid())
  contributionType    ContributionType
  calculationMethod   ContributionCalculationMethod
  baseKind            ContributionBaseKind
  payrollFrequency    PayrollFrequency?
  lowerBound          Decimal                       @db.Decimal(12, 2)
  upperBound          Decimal?                      @db.Decimal(12, 2)
  employeeFixedAmount Decimal?                      @db.Decimal(12, 2)
  employerFixedAmount Decimal?                      @db.Decimal(12, 2)
  employeeRate        Decimal?                      @db.Decimal(8, 6)
  employerRate        Decimal?                      @db.Decimal(8, 6)
  baseTax             Decimal?                      @db.Decimal(12, 2)
  marginalRate        Decimal?                      @db.Decimal(8, 6)
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  referenceCode       String?
  metadata            Json?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@index([contributionType, payrollFrequency, effectiveFrom])
  @@index([contributionType, effectiveFrom, lowerBound])
  @@index([effectiveFrom, effectiveTo])
}

model PositionRateHistory {
  id              String    @id @default(cuid())
  positionId      String
  dailyRate       Decimal?  @db.Decimal(10, 2)
  hourlyRate      Decimal?  @db.Decimal(10, 2)
  monthlyRate     Decimal?  @db.Decimal(12, 2)
  currencyCode    String    @default("PHP")
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  reason          String?
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime  @default(now())

  position  Position @relation(fields: [positionId], references: [positionId], onDelete: Cascade)
  createdBy User?    @relation("PositionRateHistoryCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)

  @@unique([positionId, effectiveFrom])
  @@index([positionId, effectiveFrom])
  @@index([createdByUserId])
}

model EmployeePositionHistory {
  id              String      @id @default(cuid())
  employeeId      String
  departmentId    String?
  positionId      String?
  effectiveFrom   DateTime    @default(now())
  effectiveTo     DateTime?
  reason          String?
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime    @default(now())
  employee        Employee    @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  department      Department? @relation(fields: [departmentId], references: [departmentId], onDelete: SetNull)
  position        Position?   @relation(fields: [positionId], references: [positionId], onDelete: SetNull)
  createdBy       User?       @relation("EmployeePositionHistoryCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)

  @@index([employeeId, effectiveFrom])
  @@index([departmentId])
  @@index([positionId])
}

model Shift {
  id                 Int      @id @default(autoincrement())
  code               String   @unique
  name               String
  colorHex           String?
  isDayOff           Boolean  @default(false)
  startMinutes       Int // minutes since midnight (e.g., 9:00 AM -> 540)
  endMinutes         Int // minutes since midnight (e.g., 6:00 PM -> 1080)
  spansMidnight      Boolean  @default(false) // true when end wraps past midnight
  breakStartMinutes  Int?
  breakEndMinutes    Int?
  breakMinutesUnpaid Int      @default(0)
  paidHoursPerDay    Decimal  @db.Decimal(5, 2) // e.g., 8.00
  isActive           Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations to weekly schedules per day
  weeklySchedulesSun WeeklySchedule[] @relation("ws_sun")
  weeklySchedulesMon WeeklySchedule[] @relation("ws_mon")
  weeklySchedulesTue WeeklySchedule[] @relation("ws_tue")
  weeklySchedulesWed WeeklySchedule[] @relation("ws_wed")
  weeklySchedulesThu WeeklySchedule[] @relation("ws_thu")
  weeklySchedulesFri WeeklySchedule[] @relation("ws_fri")
  weeklySchedulesSat WeeklySchedule[] @relation("ws_sat")

  // Usage
  overrides              EmployeeShiftOverride[]
  attendances            Attendance[]            @relation("attendance_expected_shift")
  scheduleChangeRequests ScheduleChangeRequest[]

  @@index([name])
}

/// One weekly schedule row per employee and week start (Monday anchor).
model WeeklySchedule {
  id         String   @id @default(cuid())
  employeeId String
  weekStart  DateTime
  monShiftId Int?
  tueShiftId Int?
  wedShiftId Int?
  thuShiftId Int?
  friShiftId Int?
  satShiftId Int?
  sunShiftId Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  monShift Shift?   @relation("ws_mon", fields: [monShiftId], references: [id])
  tueShift Shift?   @relation("ws_tue", fields: [tueShiftId], references: [id])
  wedShift Shift?   @relation("ws_wed", fields: [wedShiftId], references: [id])
  thuShift Shift?   @relation("ws_thu", fields: [thuShiftId], references: [id])
  friShift Shift?   @relation("ws_fri", fields: [friShiftId], references: [id])
  satShift Shift?   @relation("ws_sat", fields: [satShiftId], references: [id])
  sunShift Shift?   @relation("ws_sun", fields: [sunShiftId], references: [id])

  @@unique([employeeId, weekStart])
  @@index([weekStart])
}

/// One-day exception that replaces the pattern-based shift.
model EmployeeShiftOverride {
  id         String   @id @default(cuid())
  employeeId String
  workDate   DateTime // date anchor (use start day for overnight)
  shiftId    Int? // null = mark as rest day
  source     String // "MANUAL", "APPROVED_REQUEST"
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, workDate])
  @@index([workDate])
}

/// Daily attendance snapshot; expected times come from pattern/override.
model Attendance {
  id             String            @id @default(cuid())
  employeeId     String
  workDate       DateTime
  status         ATTENDANCE_STATUS
  isPaidLeave    Boolean           @default(false)
  leaveRequestId String?

  // Expected
  expectedShiftId       Int?
  scheduledStartMinutes Int?
  scheduledEndMinutes   Int?
  paidHoursPerDay       Decimal? @db.Decimal(5, 2)

  // Actuals
  actualInAt           DateTime?
  actualOutAt          DateTime?
  workedMinutes        Int?
  breakMinutes         Int       @default(0)
  // Break minutes deducted for payroll (policy-driven, e.g. max(scheduled, actual)).
  deductedBreakMinutes Int       @default(0)
  // Net payable minutes after deducted break.
  netWorkedMinutes     Int?
  breakCount           Int       @default(0)

  // Variances
  lateMinutes             Int @default(0)
  undertimeMinutes        Int @default(0)
  overtimeMinutesRaw      Int @default(0)
  overtimeMinutesApproved Int @default(0)
  nightMinutes            Int @default(0)

  // Posting/lock
  isLocked          Boolean @default(false)
  payrollPeriodId   String?
  payrollEmployeeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee                 Employee                  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  expectedShift            Shift?                    @relation("attendance_expected_shift", fields: [expectedShiftId], references: [id])
  leaveRequest             LeaveRequest?             @relation(fields: [leaveRequestId], references: [id], onDelete: SetNull)
  payroll                  Payroll?                  @relation("PayrollAttendanceRows", fields: [payrollPeriodId], references: [payrollId], onDelete: SetNull)
  payrollEmployee          PayrollEmployee?          @relation("PayrollEmployeeAttendanceRows", fields: [payrollEmployeeId], references: [id], onDelete: SetNull)
  punches                  Punch[]
  contextLogs              AttendanceContextLog[]
  faceVerificationAttempts FaceVerificationAttempt[]

  @@unique([employeeId, workDate])
  @@index([employeeId, workDate])
  @@index([workDate])
  @@index([status, workDate])
  @@index([isLocked, workDate])
  @@index([leaveRequestId])
  @@index([payrollPeriodId])
  @@index([payrollEmployeeId])
}

/// Raw punch events; use them to recompute Attendance in real time.
model Punch {
  id           String     @id @default(cuid())
  employeeId   String
  attendanceId String?
  punchTime    DateTime
  punchType    PUNCH_TYPE
  source       String? // e.g., "BIOMETRIC", "WEB"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  employee                 Employee                  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  attendance               Attendance?               @relation(fields: [attendanceId], references: [id])
  faceVerificationAttempts FaceVerificationAttempt[]

  @@index([employeeId, punchTime])
  @@index([punchTime])
  @@index([attendanceId])
}

model AttendanceSecuritySetting {
  id                     String   @id @default("default")
  gpsValidationEnabled   Boolean  @default(false)
  faceRecognitionEnabled Boolean  @default(false)
  faceRequiredForQrPunch Boolean  @default(false)
  faceLivenessRequired   Boolean  @default(true)
  faceMatchMaxDistance   Decimal  @default(0.50) @db.Decimal(4, 2)
  faceFailureMode        String   @default("BLOCK")
  updatedByUserId        String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  updatedBy User? @relation("AttendanceSecuritySettingUpdatedBy", fields: [updatedByUserId], references: [userId], onDelete: SetNull)

  @@index([updatedByUserId, updatedAt])
}

model EmployeeFaceEnrollment {
  id               String    @id @default(cuid())
  employeeId       String
  embedding        Bytes
  sampleCount      Int       @default(0)
  modelVersion     String
  consentText      String?
  consentedAt      DateTime?
  enrolledByUserId String?
  revokedByUserId  String?
  revokedAt        DateTime?
  revokeReason     String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  employee   Employee @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  enrolledBy User?    @relation("EmployeeFaceEnrollmentEnrolledBy", fields: [enrolledByUserId], references: [userId], onDelete: SetNull)
  revokedBy  User?    @relation("EmployeeFaceEnrollmentRevokedBy", fields: [revokedByUserId], references: [userId], onDelete: SetNull)

  @@index([employeeId, isActive, createdAt])
  @@index([enrolledByUserId, createdAt])
  @@index([revokedByUserId, revokedAt])
}

model FaceVerificationAttempt {
  id               String      @id @default(cuid())
  employeeId       String
  attendanceId     String?
  punchId          String?
  kioskId          String?
  kioskNonce       String?
  punchType        PUNCH_TYPE?
  status           String
  reason           String?
  distance         Decimal?    @db.Decimal(8, 6)
  threshold        Decimal?    @db.Decimal(4, 2)
  livenessPassed   Boolean?
  livenessPrompt   String?
  faceCount        Int?
  modelVersion     String?
  serviceLatencyMs Int?
  details          Json?
  createdAt        DateTime    @default(now())

  employee   Employee    @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  attendance Attendance? @relation(fields: [attendanceId], references: [id], onDelete: SetNull)
  punch      Punch?      @relation(fields: [punchId], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt])
  @@index([attendanceId])
  @@index([punchId])
  @@index([status, createdAt])
  @@index([kioskId, createdAt])
}

model AttendanceContextLog {
  id           String   @id @default(cuid())
  attendanceId String
  employeeId   String
  ipAddress    String?
  userAgent    String?
  latitude     Decimal? @db.Decimal(9, 6)
  longitude    Decimal? @db.Decimal(9, 6)
  createdAt    DateTime @default(now())

  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([attendanceId])
  @@index([employeeId, createdAt])
}

model EmployeeViolation {
  id                   String                  @id @default(cuid())
  employeeId           String
  violationId          String
  violationDate        DateTime
  strikePointsSnapshot Int                     @default(1)
  status               EmployeeViolationStatus @default(DRAFT)
  draftedById          String?
  submittedAt          DateTime?
  reviewedById         String?
  reviewedAt           DateTime?
  reviewRemarks        String?
  isAcknowledged       Boolean                 @default(false)
  acknowledgedAt       DateTime?
  remarks              String?
  isCountedForStrike   Boolean                 @default(true)
  voidedAt             DateTime?
  voidReason           String?
  createdAt            DateTime                @default(now())

  violation  Violation @relation(fields: [violationId], references: [violationId], onDelete: Cascade)
  employee   Employee  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  draftedBy  User?     @relation("EmployeeViolationDraftedBy", fields: [draftedById], references: [userId])
  reviewedBy User?     @relation("EmployeeViolationReviewedBy", fields: [reviewedById], references: [userId])

  @@index([employeeId, violationDate])
  @@index([violationId])
  @@index([status, violationDate])
  @@index([draftedById])
  @@index([reviewedById])
  @@index([isCountedForStrike, voidedAt])
}

model Violation {
  violationId           String   @id @default(cuid())
  name                  String
  description           String
  defaultStrikePoints   Int      @default(1)
  // Per employee cap for counted strikes of this violation type.
  maxStrikesPerEmployee Int      @default(3)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  employeeViolations EmployeeViolation[]
  violationResets    EmployeeViolationReset[]
  autoResetPolicies  ViolationAutoResetPolicy[]

  @@index([name])
}

model EmployeeViolationReset {
  id              String   @id @default(cuid())
  employeeId      String
  violationId     String?
  effectiveFrom   DateTime
  reason          String
  createdByUserId String?
  autoPolicyId    String?
  createdAt       DateTime @default(now())

  employee   Employee                  @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  violation  Violation?                @relation(fields: [violationId], references: [violationId], onDelete: Cascade)
  createdBy  User?                     @relation("EmployeeViolationResetCreatedBy", fields: [createdByUserId], references: [userId])
  autoPolicy ViolationAutoResetPolicy? @relation("ViolationAutoResetPolicyResets", fields: [autoPolicyId], references: [id], onDelete: SetNull)

  @@index([employeeId, effectiveFrom])
  @@index([employeeId, violationId, effectiveFrom])
  @@index([createdAt])
}

model ViolationAutoResetPolicy {
  id                    String                  @id @default(cuid())
  name                  String?
  frequency             ViolationResetFrequency
  dayOfMonth            Int                     @default(1)
  monthOfYear           Int?
  effectiveFrom         DateTime                @default(now())
  nextRunAt             DateTime
  lastRunAt             DateTime?
  reasonTemplate        String?
  appliesToAllEmployees Boolean                 @default(true)
  employeeId            String?
  violationId           String?
  isActive              Boolean                 @default(true)
  createdByUserId       String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  employee  Employee?                @relation(fields: [employeeId], references: [employeeId], onDelete: SetNull)
  violation Violation?               @relation(fields: [violationId], references: [violationId], onDelete: SetNull)
  createdBy User?                    @relation("ViolationAutoResetPolicyCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  resets    EmployeeViolationReset[] @relation("ViolationAutoResetPolicyResets")

  @@index([isActive, nextRunAt])
  @@index([employeeId])
  @@index([violationId])
  @@index([frequency, dayOfMonth, monthOfYear])
}

model DeductionType {
  id              String              @id @default(cuid())
  code            String              @unique
  name            String
  description     String?
  // FIXED = flat amount per trigger; PERCENT = percentage-based deduction.
  amountMode      DeductionAmountMode
  // ONE_TIME, every payroll, or recurring installment mode.
  frequency       DeductionFrequency  @default(PER_PAYROLL)
  // Defaults used when assignment does not override value.
  defaultAmount   Decimal?            @db.Decimal(12, 2)
  defaultPercent  Decimal?            @db.Decimal(5, 2)
  isActive        Boolean             @default(true)
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  assignments       EmployeeDeductionAssignment[]
  payrollDeductions PayrollDeduction[]
  createdBy         User?                         @relation("DeductionTypeCreatedBy", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  updatedBy         User?                         @relation("DeductionTypeUpdatedBy", fields: [updatedByUserId], references: [userId], onDelete: SetNull)

  @@index([isActive, name])
}

model EmployeeDeductionAssignment {
  id                    String                            @id @default(cuid())
  employeeId            String
  deductionTypeId       String
  // Assignment is applied only when payroll period is within this range.
  effectiveFrom         DateTime
  effectiveTo           DateTime?
  // Optional per employee override over DeductionType defaults.
  amountOverride        Decimal?                          @db.Decimal(12, 2)
  percentOverride       Decimal?                          @db.Decimal(5, 2)
  // Installment fields support cash advance/loan style repayments.
  installmentTotal      Decimal?                          @db.Decimal(12, 2)
  installmentPerPayroll Decimal?                          @db.Decimal(12, 2)
  remainingBalance      Decimal?                          @db.Decimal(12, 2)
  workflowStatus        EmployeeDeductionWorkflowStatus   @default(APPROVED)
  // ACTIVE participates in payroll; PAUSED/CANCELLED are skipped; COMPLETED is fully settled.
  status                EmployeeDeductionAssignmentStatus @default(ACTIVE)
  reason                String?
  assignedByUserId      String?
  updatedByUserId       String?
  submittedAt           DateTime?
  reviewedByUserId      String?
  reviewedAt            DateTime?
  reviewRemarks         String?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt

  employee           Employee                   @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  deductionType      DeductionType              @relation(fields: [deductionTypeId], references: [id], onDelete: Restrict)
  payrollDeductions  PayrollDeduction[]
  payments           EmployeeDeductionPayment[]
  cashAdvanceRequest CashAdvanceRequest?
  assignedBy         User?                      @relation("EmployeeDeductionAssignmentAssignedBy", fields: [assignedByUserId], references: [userId], onDelete: SetNull)
  updatedBy          User?                      @relation("EmployeeDeductionAssignmentUpdatedBy", fields: [updatedByUserId], references: [userId], onDelete: SetNull)
  reviewedBy         User?                      @relation("EmployeeDeductionAssignmentReviewedBy", fields: [reviewedByUserId], references: [userId], onDelete: SetNull)

  @@unique([employeeId, deductionTypeId, effectiveFrom])
  @@index([employeeId, status, effectiveFrom])
  @@index([deductionTypeId, status])
  @@index([workflowStatus, employeeId, effectiveFrom])
  @@index([assignedByUserId, workflowStatus, updatedAt])
}

model CashAdvanceRequest {
  id                    String                   @id @default(cuid())
  employeeId            String
  amount                Decimal                  @db.Decimal(12, 2)
  repaymentPerPayroll   Decimal                  @db.Decimal(12, 2)
  preferredStartDate    DateTime
  approvedAmount        Decimal?                 @db.Decimal(12, 2)
  approvedDeductionMode CashAdvanceDeductionMode?
  approvedRepaymentPerPayroll Decimal?           @db.Decimal(12, 2)
  approvedEffectiveFrom DateTime?
  reason                String?
  status                CashAdvanceRequestStatus @default(PENDING_MANAGER)
  managerRemarks        String?
  submittedAt           DateTime                 @default(now())
  reviewedByUserId      String?
  reviewedAt            DateTime?
  deductionAssignmentId String?                  @unique
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  employee            Employee                     @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)
  reviewedBy          User?                        @relation("CashAdvanceRequestReviewedBy", fields: [reviewedByUserId], references: [userId], onDelete: SetNull)
  deductionAssignment EmployeeDeductionAssignment? @relation(fields: [deductionAssignmentId], references: [id], onDelete: SetNull)

  @@index([employeeId, status, submittedAt])
  @@index([status, submittedAt])
  @@index([reviewedByUserId, reviewedAt])
}

model LeaveRequest {
